<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartLog.Scanner.Views.AboutPage"
             Title="About"
             BackgroundColor="#F8F9FA">

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="40,40">

            <!-- Card Container -->
            <Border BackgroundColor="White"
                    StrokeThickness="0"
                    Padding="40,48"
                    HorizontalOptions="Center"
                    WidthRequest="420">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Opacity="0.1" Radius="20" Offset="0,6" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="24" HorizontalOptions="Center">

                    <!-- Logo Icon -->
                    <Border WidthRequest="80"
                            HeightRequest="80"
                            BackgroundColor="#E0F2F1"
                            HorizontalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="40" />
                        </Border.StrokeShape>
                        <Label Text="📱"
                               FontSize="36"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>

                    <!-- App Name -->
                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Label Text="SmartLog Scanner"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="#2C5F5D"
                               HorizontalTextAlignment="Center" />
                        <Label Text="QR Code Attendance Scanner"
                               FontSize="14"
                               TextColor="#78909C"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>

                    <!-- Version Badge -->
                    <Border BackgroundColor="#F5F5F5"
                            Padding="16,8"
                            StrokeThickness="1"
                            Stroke="#E0E0E0"
                            HorizontalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Label Text="Version 1.0.0"
                               FontSize="14"
                               TextColor="#37474F"
                               HorizontalTextAlignment="Center" />
                    </Border>

                    <!-- Divider -->
                    <BoxView HeightRequest="1" Color="#EEEEEE" HorizontalOptions="Fill" />

                    <!-- Description -->
                    <Label Text="SmartLog Scanner is the companion app for the SmartLog School Attendance System. It reads student QR codes via camera, validates them locally using HMAC-SHA256, and submits attendance records to the SmartLog server."
                           FontSize="13"
                           TextColor="#78909C"
                           HorizontalTextAlignment="Center"
                           LineHeight="1.5" />

                    <!-- Divider -->
                    <BoxView HeightRequest="1" Color="#EEEEEE" HorizontalOptions="Fill" />

                    <!-- Author -->
                    <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                        <Label Text="DEVELOPED BY"
                               FontSize="10"
                               FontAttributes="Bold"
                               TextColor="#9E9E9E"
                               CharacterSpacing="1.5"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Mark Daniel Marmeto"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#37474F"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>

                    <!-- Divider -->
                    <BoxView HeightRequest="1" Color="#EEEEEE" HorizontalOptions="Fill" />

                    <!-- Tech Stack -->
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="BUILT WITH"
                               FontSize="10"
                               FontAttributes="Bold"
                               TextColor="#9E9E9E"
                               CharacterSpacing="1.5"
                               HorizontalTextAlignment="Center" />
                        <FlexLayout Direction="Row"
                                    Wrap="Wrap"
                                    JustifyContent="Center"
                                    AlignItems="Center">
                            <Border BackgroundColor="#F5F5F5" Padding="10,5" Margin="3" StrokeThickness="1" Stroke="#E0E0E0">
                                <Border.StrokeShape><RoundRectangle CornerRadius="6" /></Border.StrokeShape>
                                <Label Text=".NET MAUI" FontSize="12" TextColor="#37474F" />
                            </Border>
                            <Border BackgroundColor="#F5F5F5" Padding="10,5" Margin="3" StrokeThickness="1" Stroke="#E0E0E0">
                                <Border.StrokeShape><RoundRectangle CornerRadius="6" /></Border.StrokeShape>
                                <Label Text=".NET 8.0" FontSize="12" TextColor="#37474F" />
                            </Border>
                            <Border BackgroundColor="#F5F5F5" Padding="10,5" Margin="3" StrokeThickness="1" Stroke="#E0E0E0">
                                <Border.StrokeShape><RoundRectangle CornerRadius="6" /></Border.StrokeShape>
                                <Label Text="HMAC-SHA256" FontSize="12" TextColor="#37474F" />
                            </Border>
                            <Border BackgroundColor="#F5F5F5" Padding="10,5" Margin="3" StrokeThickness="1" Stroke="#E0E0E0">
                                <Border.StrokeShape><RoundRectangle CornerRadius="6" /></Border.StrokeShape>
                                <Label Text="ZXing" FontSize="12" TextColor="#37474F" />
                            </Border>
                        </FlexLayout>
                    </VerticalStackLayout>

                    <!-- Divider -->
                    <BoxView HeightRequest="1" Color="#EEEEEE" HorizontalOptions="Fill" />

                    <!-- Copyright -->
                    <Label Text="&#169; 2026 SmartLog. All rights reserved."
                           FontSize="12"
                           TextColor="#9E9E9E"
                           HorizontalTextAlignment="Center" />

                </VerticalStackLayout>
            </Border>

            <!-- Back Button -->
            <Button Text="Back"
                    FontSize="14"
                    BackgroundColor="#2C5F5D"
                    TextColor="White"
                    CornerRadius="10"
                    Padding="24,12"
                    HorizontalOptions="Center"
                    Margin="0,24,0,0"
                    Clicked="OnBackClicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
