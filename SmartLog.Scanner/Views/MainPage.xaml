<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SmartLog.Scanner.ViewModels"
             xmlns:controls="clr-namespace:SmartLog.Scanner.Controls"
             x:Class="SmartLog.Scanner.Views.MainPage"
             x:DataType="vm:MainViewModel"
             Title="SmartLog Scanner"
             BackgroundColor="#F8F9FA">

    <!-- US0124: Three-row layout — StatusBar / Body (preview + station cards) / Stats footer.
         The shared central student card and bottom feedback banner are removed; each station
         card carries its own student-detail block + coloured bottom banner. -->
    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ─────────────────────────── Top Status Bar ─────────────────────────── -->
        <Border Grid.Row="0"
                BackgroundColor="White"
                Padding="20,15"
                StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.1" Radius="8" Offset="0,2" />
            </Border.Shadow>

            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto,Auto,Auto,Auto">
                <!-- US0092: Date/Time block — left-most for glance readability -->
                <VerticalStackLayout Grid.Column="0"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Start"
                                     Spacing="0"
                                     Margin="0,0,16,0">
                    <Label Text="{Binding CurrentTime}"
                           Style="{StaticResource HeaderTimeLabel}" />
                    <Label Text="{Binding CurrentDate}"
                           Style="{StaticResource HeaderDateLabel}" />
                </VerticalStackLayout>

                <!-- App Logo -->
                <Image Grid.Column="1"
                       Source="smartlog_logo.svg"
                       HeightRequest="30"
                       WidthRequest="154"
                       Aspect="AspectFit"
                       VerticalOptions="Center"
                       Margin="0,0,12,0" />

                <!-- Spacer -->
                <BoxView Grid.Column="2" Color="Transparent" />

                <!-- US0015: Enhanced Connectivity Status with Glass Effect -->
                <Border Grid.Column="3"
                        BackgroundColor="{Binding ConnectivityColor}"
                        Padding="14,8"
                        StrokeThickness="0"
                        VerticalOptions="Center"
                        Margin="0,0,10,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="{Binding ConnectivityColor}" Opacity="0.3" Radius="6" Offset="0,2" />
                    </Border.Shadow>
                    <HorizontalStackLayout Spacing="8">
                        <Border WidthRequest="8"
                                HeightRequest="8"
                                BackgroundColor="White"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="4" />
                            </Border.StrokeShape>
                        </Border>
                        <Label Text="{Binding ConnectivityStatus}"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="White"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <!-- US0009: Scan Type Toggle -->
                <Border Grid.Column="4"
                        BackgroundColor="#4D9B91"
                        Padding="18,10"
                        StrokeThickness="0"
                        VerticalOptions="Center"
                        Margin="0,0,10,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#4D9B91" Opacity="0.4" Radius="8" Offset="0,3" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleScanTypeCommand}" />
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="🔄"
                               FontSize="16"
                               VerticalOptions="Center" />
                        <Label Text="{Binding CurrentScanType, StringFormat='{0} Mode'}"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="White"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <!-- View Logs Button -->
                <Button Grid.Column="5"
                        Text="📊"
                        FontSize="18"
                        BackgroundColor="Transparent"
                        TextColor="#4D9B91"
                        Clicked="OnViewLogsClicked"
                        VerticalOptions="Center"
                        Padding="8,4"
                        Margin="0,0,10,0" />

                <!-- Settings Button -->
                <Button Grid.Column="6"
                        Text="⚙️"
                        FontSize="18"
                        BackgroundColor="Transparent"
                        TextColor="#4D9B91"
                        Clicked="OnSettingsClicked"
                        VerticalOptions="Center"
                        Padding="8,4"
                        Margin="0,0,10,0" />

                <!-- About Button -->
                <Button Grid.Column="7"
                        Text="ℹ️"
                        FontSize="18"
                        BackgroundColor="Transparent"
                        TextColor="#4D9B91"
                        Clicked="OnAboutClicked"
                        VerticalOptions="Center"
                        Padding="8,4"
                        Margin="0,0,10,0" />

                <!-- Scanning Status -->
                <HorizontalStackLayout Grid.Column="8"
                                       Spacing="8"
                                       VerticalOptions="Center">
                    <Label Text="{Binding StatusIcon}"
                           FontSize="18"
                           VerticalOptions="Center" />
                    <Label Text="{Binding StatusMessage}"
                           FontSize="14"
                           TextColor="#666666"
                           VerticalOptions="Center" />
                    <ActivityIndicator IsRunning="{Binding IsScanning}"
                                       IsVisible="{Binding IsScanning}"
                                       Color="#4D9B91"
                                       WidthRequest="16"
                                       HeightRequest="16" />
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <!-- ─────────────────────────────── Body ─────────────────────────────── -->
        <!-- US0124: Single column. Camera 0 preview at top (when in camera mode), then
             adaptive row of station cards below (cameras + USB). Body width feeds
             MainViewModel.BodyWidth via SizeChanged so CardWidth divides equally. -->
        <Grid Grid.Row="1"
              x:Name="BodyGrid"
              SizeChanged="OnBodyGridSizeChanged"
              RowDefinitions="Auto,*"
              Padding="12,8,12,8"
              BackgroundColor="#F8F9FA">

            <!-- Camera 0 live preview — visible only in camera-active modes -->
            <Border Grid.Row="0"
                    IsVisible="{Binding IsCameraMode}"
                    HeightRequest="240"
                    WidthRequest="320"
                    HorizontalOptions="Center"
                    BackgroundColor="Black"
                    Stroke="#2C5F5D"
                    StrokeThickness="2"
                    Margin="0,4,0,12">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Opacity="0.15" Radius="10" Offset="0,3" />
                </Border.Shadow>
                <controls:CameraPreviewView x:Name="CameraPreview0" />
            </Border>

            <!-- Adaptive station cards row -->
            <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Default">
                <VerticalStackLayout Spacing="0">

                    <!-- Camera slot cards (1–8) -->
                    <FlexLayout BindableLayout.ItemsSource="{Binding CameraSlots}"
                                Direction="Row"
                                Wrap="Wrap"
                                JustifyContent="Center"
                                AlignItems="Start">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:CameraSlotState">
                                <Border IsVisible="{Binding IsVisible}"
                                        WidthRequest="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CardWidth}"
                                        MinimumWidthRequest="260"
                                        Margin="6"
                                        BackgroundColor="White"
                                        Stroke="{Binding DisplayBrush}"
                                        StrokeThickness="2"
                                        Padding="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12" />
                                    </Border.StrokeShape>
                                    <Border.Shadow>
                                        <Shadow Brush="Black" Opacity="0.08" Radius="10" Offset="0,3" />
                                    </Border.Shadow>

                                    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="0">

                                        <!-- HEADER: Camera name + scan type badge + result icon -->
                                        <Grid Grid.Row="0"
                                              ColumnDefinitions="Auto,*,Auto"
                                              Padding="16,12,16,8"
                                              ColumnSpacing="8">
                                            <Label Grid.Column="0"
                                                   Text="{Binding FlashIcon}"
                                                   FontSize="18"
                                                   FontAttributes="Bold"
                                                   TextColor="{Binding FlashColor}"
                                                   VerticalOptions="Center"
                                                   IsVisible="{Binding ShowFlash}" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding DisplayName}"
                                                   FontSize="15"
                                                   FontAttributes="Bold"
                                                   TextColor="#2C5F5D"
                                                   VerticalOptions="Center"
                                                   LineBreakMode="TailTruncation" />
                                            <Border Grid.Column="2"
                                                    BackgroundColor="{Binding ScanTypeBadgeColor}"
                                                    Padding="8,3"
                                                    StrokeThickness="0"
                                                    VerticalOptions="Center">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="5" />
                                                </Border.StrokeShape>
                                                <Label Text="{Binding ScanType}"
                                                       FontSize="11"
                                                       FontAttributes="Bold"
                                                       TextColor="White" />
                                            </Border>
                                        </Grid>

                                        <!-- BODY: Idle status OR student details -->
                                        <Grid Grid.Row="1"
                                              Padding="16,4,16,16"
                                              RowDefinitions="Auto,Auto,Auto,*"
                                              RowSpacing="6">

                                            <!-- Idle: status text only -->
                                            <Label Grid.Row="0"
                                                   Text="{Binding StatusText}"
                                                   FontSize="14"
                                                   TextColor="#666666"
                                                   VerticalOptions="Center"
                                                   IsVisible="{Binding ShowFlash, Converter={StaticResource InvertedBoolConverter}}" />

                                            <!-- Flash: student number / visitor pass header -->
                                            <Label Grid.Row="0"
                                                   Text="{Binding FlashStudentName}"
                                                   FontSize="22"
                                                   FontAttributes="Bold"
                                                   TextColor="{Binding FlashColor}"
                                                   LineBreakMode="TailTruncation"
                                                   IsVisible="{Binding ShowFlash}" />

                                            <!-- Flash + non-visitor: LRN row -->
                                            <Grid Grid.Row="1"
                                                  ColumnDefinitions="Auto,*"
                                                  ColumnSpacing="10"
                                                  IsVisible="{Binding ShowFlash}">
                                                <Label Grid.Column="0"
                                                       Text="LRN"
                                                       FontSize="10"
                                                       FontAttributes="Bold"
                                                       TextColor="#9E9E9E"
                                                       CharacterSpacing="1.5"
                                                       VerticalOptions="Center" />
                                                <Label Grid.Column="1"
                                                       Text="{Binding LastLrn, TargetNullValue='N/A'}"
                                                       FontSize="14"
                                                       TextColor="#546E7A"
                                                       VerticalOptions="Center"
                                                       LineBreakMode="TailTruncation" />
                                            </Grid>

                                            <!-- Flash: Grade · Program · Section -->
                                            <Label Grid.Row="2"
                                                   Text="{Binding LastGradeSection}"
                                                   FontSize="14"
                                                   TextColor="#37474F"
                                                   LineBreakMode="TailTruncation"
                                                   IsVisible="{Binding ShowFlash}" />
                                        </Grid>

                                        <!-- BOTTOM BANNER (per-card replacement for the deleted shared banner) -->
                                        <Border Grid.Row="2"
                                                BackgroundColor="{Binding FlashColor}"
                                                StrokeThickness="0"
                                                Padding="14,10"
                                                IsVisible="{Binding ShowFlash}">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="0,0,11,11" />
                                            </Border.StrokeShape>
                                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                                <Label Grid.Column="0"
                                                       Text="{Binding FlashIcon}"
                                                       FontSize="20"
                                                       TextColor="White"
                                                       VerticalOptions="Center" />
                                                <Label Grid.Column="1"
                                                       Text="{Binding LastScanMessage}"
                                                       FontSize="13"
                                                       FontAttributes="Bold"
                                                       TextColor="White"
                                                       LineBreakMode="WordWrap"
                                                       MaxLines="2"
                                                       VerticalOptions="Center" />
                                                <Label Grid.Column="2"
                                                       Text="{Binding LastScanTime}"
                                                       FontSize="11"
                                                       TextColor="White"
                                                       Opacity="0.9"
                                                       VerticalOptions="Center" />
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>

                    <!-- USB indicator card (peer with camera cards) -->
                    <Border IsVisible="{Binding UsbScannerSlot.IsVisible}"
                            WidthRequest="{Binding CardWidth}"
                            MinimumWidthRequest="260"
                            HorizontalOptions="Center"
                            Margin="6,12,6,6"
                            BackgroundColor="White"
                            Stroke="{Binding UsbScannerSlot.DisplayColor}"
                            StrokeThickness="2"
                            Padding="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Opacity="0.08" Radius="10" Offset="0,3" />
                        </Border.Shadow>

                        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="0">

                            <!-- HEADER: barcode glyph + name + scan type badge -->
                            <Grid Grid.Row="0"
                                  ColumnDefinitions="Auto,*,Auto"
                                  Padding="16,12,16,8"
                                  ColumnSpacing="8">
                                <Path Grid.Column="0"
                                      Data="M0,0 L2,0 L2,16 L0,16 Z M4,0 L5,0 L5,16 L4,16 Z M7,0 L9,0 L9,16 L7,16 Z M11,0 L12,0 L12,16 L11,16 Z M14,0 L16,0 L16,16 L14,16 Z"
                                      Fill="#6A4C93"
                                      WidthRequest="16"
                                      HeightRequest="16"
                                      VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Text="{Binding UsbScannerSlot.DisplayName}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="#6A4C93"
                                       VerticalOptions="Center"
                                       LineBreakMode="TailTruncation" />
                                <Border Grid.Column="2"
                                        BackgroundColor="{Binding UsbScannerSlot.ScanTypeBadgeColor}"
                                        Padding="8,3"
                                        StrokeThickness="0"
                                        VerticalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="5" />
                                    </Border.StrokeShape>
                                    <Label Text="{Binding UsbScannerSlot.ScanType}"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="White" />
                                </Border>
                            </Grid>

                            <!-- BODY: idle status OR student details -->
                            <Grid Grid.Row="1"
                                  Padding="16,4,16,16"
                                  RowDefinitions="Auto,Auto,Auto,*"
                                  RowSpacing="6">

                                <!-- Idle: status text -->
                                <Label Grid.Row="0"
                                       Text="{Binding UsbScannerSlot.StatusText}"
                                       FontSize="14"
                                       TextColor="#666666"
                                       VerticalOptions="Center"
                                       IsVisible="{Binding UsbScannerSlot.ShowFlash, Converter={StaticResource InvertedBoolConverter}}" />

                                <!-- Flash: subject name -->
                                <Label Grid.Row="0"
                                       Text="{Binding UsbScannerSlot.FlashStudentName}"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="{Binding UsbScannerSlot.FlashColor}"
                                       LineBreakMode="TailTruncation"
                                       IsVisible="{Binding UsbScannerSlot.ShowFlash}" />

                                <!-- Flash + non-visitor: LRN -->
                                <Grid Grid.Row="1"
                                      ColumnDefinitions="Auto,*"
                                      ColumnSpacing="10"
                                      IsVisible="{Binding UsbScannerSlot.ShowFlash}">
                                    <Label Grid.Column="0"
                                           Text="LRN"
                                           FontSize="10"
                                           FontAttributes="Bold"
                                           TextColor="#9E9E9E"
                                           CharacterSpacing="1.5"
                                           VerticalOptions="Center" />
                                    <Label Grid.Column="1"
                                           Text="{Binding UsbScannerSlot.LastLrn, TargetNullValue='N/A'}"
                                           FontSize="14"
                                           TextColor="#546E7A"
                                           VerticalOptions="Center"
                                           LineBreakMode="TailTruncation" />
                                </Grid>

                                <!-- Flash: Grade · Program · Section -->
                                <Label Grid.Row="2"
                                       Text="{Binding UsbScannerSlot.LastGradeSection}"
                                       FontSize="14"
                                       TextColor="#37474F"
                                       LineBreakMode="TailTruncation"
                                       IsVisible="{Binding UsbScannerSlot.ShowFlash}" />
                            </Grid>

                            <!-- BOTTOM BANNER -->
                            <Border Grid.Row="2"
                                    BackgroundColor="{Binding UsbScannerSlot.FlashColor}"
                                    StrokeThickness="0"
                                    Padding="14,10"
                                    IsVisible="{Binding UsbScannerSlot.ShowFlash}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="0,0,11,11" />
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                    <Label Grid.Column="0"
                                           Text="{Binding UsbScannerSlot.FlashIcon}"
                                           FontSize="20"
                                           TextColor="White"
                                           VerticalOptions="Center" />
                                    <Label Grid.Column="1"
                                           Text="{Binding UsbScannerSlot.LastScanMessage}"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="White"
                                           LineBreakMode="WordWrap"
                                           MaxLines="2"
                                           VerticalOptions="Center" />
                                    <Label Grid.Column="2"
                                           Text="{Binding UsbScannerSlot.LastScanTime}"
                                           FontSize="11"
                                           TextColor="White"
                                           Opacity="0.9"
                                           VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>
        </Grid>
        <!-- /Body -->

        <!-- ─────────────────────── Statistics Footer ─────────────────────── -->
        <!-- US0013: queue / today / sync cards. US0124 adds inline sync status label. -->
        <Border Grid.Row="2"
                BackgroundColor="#2C5F5D"
                Padding="24,16"
                StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.3" Radius="12" Offset="0,-4" />
            </Border.Shadow>

            <VerticalStackLayout Spacing="6">

                <HorizontalStackLayout Spacing="20" HorizontalOptions="Center">
                    <!-- Queue Count Card -->
                    <Border BackgroundColor="#33FFFFFF"
                            Padding="16,10"
                            StrokeThickness="0"
                            IsVisible="{Binding HasQueuedScans}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnViewQueueClicked" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="10">
                            <Border WidthRequest="40"
                                    HeightRequest="40"
                                    BackgroundColor="#FFC107"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="20" />
                                </Border.StrokeShape>
                                <Label Text="📥"
                                       FontSize="20"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Queue"
                                       FontSize="12"
                                       TextColor="#B0BEC5"
                                       VerticalOptions="End" />
                                <HorizontalStackLayout Spacing="4">
                                    <Label Text="{Binding QueuePendingCount}"
                                           FontSize="18"
                                           TextColor="White"
                                           FontAttributes="Bold"
                                           VerticalOptions="Start" />
                                    <Label Text="pending"
                                           FontSize="12"
                                           TextColor="#B0BEC5"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Today's Scan Count -->
                    <Border BackgroundColor="#33FFFFFF"
                            Padding="16,10"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <HorizontalStackLayout Spacing="10">
                            <Border WidthRequest="40"
                                    HeightRequest="40"
                                    BackgroundColor="#4CAF50"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="20" />
                                </Border.StrokeShape>
                                <Label Text="📊"
                                       FontSize="20"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Today"
                                       FontSize="12"
                                       TextColor="#B0BEC5"
                                       VerticalOptions="End" />
                                <HorizontalStackLayout Spacing="4">
                                    <Label Text="{Binding TodayScanCount}"
                                           FontSize="18"
                                           TextColor="White"
                                           FontAttributes="Bold"
                                           VerticalOptions="Start" />
                                    <Label Text="scans"
                                           FontSize="12"
                                           TextColor="#B0BEC5"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Manual Sync Button -->
                    <Border BackgroundColor="#33FFFFFF"
                            Padding="16,10"
                            StrokeThickness="0"
                            IsVisible="{Binding HasQueuedScans}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ManualSyncCommand}" />
                        </Border.GestureRecognizers>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <HorizontalStackLayout Spacing="10">
                            <Border WidthRequest="40"
                                    HeightRequest="40"
                                    BackgroundColor="#2196F3"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="20" />
                                </Border.StrokeShape>
                                <Label Text="🔄"
                                       FontSize="20"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Sync"
                                       FontSize="12"
                                       TextColor="#B0BEC5"
                                       VerticalOptions="End" />
                                <Label Text="Tap to sync"
                                       FontSize="12"
                                       TextColor="#B0BEC5"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center" />
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Border>
                </HorizontalStackLayout>

                <!-- US0124: Inline sync / queue status message (replaces deleted bottom feedback banner) -->
                <Label Text="{Binding SyncStatusMessage}"
                       FontSize="12"
                       TextColor="White"
                       Opacity="0.85"
                       HorizontalOptions="Center"
                       IsVisible="{Binding HasSyncStatusMessage}" />
            </VerticalStackLayout>
        </Border>

    </Grid>
</ContentPage>
