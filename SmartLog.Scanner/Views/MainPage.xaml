<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SmartLog.Scanner.ViewModels"
             xmlns:controls="clr-namespace:SmartLog.Scanner.Controls"
             x:Class="SmartLog.Scanner.Views.MainPage"
             x:DataType="vm:MainViewModel"
             Title="SmartLog Scanner"
             BackgroundColor="#F8F9FA">

    <!-- US0124: Three-row layout — StatusBar / Body (preview + station cards) / Stats footer.
         The shared central student card and bottom feedback banner are removed; each station
         card carries its own student-detail block + coloured bottom banner. -->
    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ─────────────────────────── Top Status Bar ─────────────────────────── -->
        <Border Grid.Row="0"
                BackgroundColor="White"
                Padding="20,15"
                StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.1" Radius="8" Offset="0,2" />
            </Border.Shadow>

            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto,Auto,Auto,Auto">
                <!-- US0092: Date/Time block — left-most for glance readability -->
                <VerticalStackLayout Grid.Column="0"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Start"
                                     Spacing="0"
                                     Margin="0,0,16,0">
                    <Label Text="{Binding CurrentTime}"
                           Style="{StaticResource HeaderTimeLabel}" />
                    <Label Text="{Binding CurrentDate}"
                           Style="{StaticResource HeaderDateLabel}" />
                </VerticalStackLayout>

                <!-- App Logo -->
                <Image Grid.Column="1"
                       Source="smartlog_logo.svg"
                       HeightRequest="30"
                       WidthRequest="154"
                       Aspect="AspectFit"
                       VerticalOptions="Center"
                       Margin="0,0,12,0" />

                <!-- Spacer -->
                <BoxView Grid.Column="2" Color="Transparent" />

                <!-- US0015: Connectivity Status pill — tap to trigger immediate refresh -->
                <Border Grid.Column="3"
                        BackgroundColor="{Binding ConnectivityColor}"
                        Padding="14,8"
                        StrokeThickness="0"
                        VerticalOptions="Center"
                        Margin="0,0,10,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="{Binding ConnectivityColor}" Opacity="0.3" Radius="6" Offset="0,2" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding RefreshConnectivityCommand}" />
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="8">
                        <!-- Dot shown when idle; spinner shown while checking -->
                        <Border WidthRequest="8"
                                HeightRequest="8"
                                BackgroundColor="White"
                                VerticalOptions="Center"
                                IsVisible="{Binding IsCheckingConnectivity, Converter={StaticResource InvertedBoolConverter}}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="4" />
                            </Border.StrokeShape>
                        </Border>
                        <ActivityIndicator IsRunning="{Binding IsCheckingConnectivity}"
                                           IsVisible="{Binding IsCheckingConnectivity}"
                                           Color="White"
                                           WidthRequest="12"
                                           HeightRequest="12"
                                           VerticalOptions="Center" />
                        <Label Text="{Binding ConnectivityStatus}"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="White"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <!-- US0009: Scan Type Toggle -->
                <Border Grid.Column="4"
                        BackgroundColor="{Binding ScanTypePillColor}"
                        Padding="18,10"
                        StrokeThickness="0"
                        VerticalOptions="Center"
                        Margin="0,0,10,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="{Binding ScanTypePillColor}" Opacity="0.4" Radius="8" Offset="0,3" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleScanTypeCommand}" />
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="🔄"
                               FontSize="16"
                               VerticalOptions="Center" />
                        <Label Text="{Binding CurrentScanType, StringFormat='{0} Mode'}"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="White"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <!-- View Logs Button -->
                <Button Grid.Column="5"
                        Text="📊"
                        FontSize="18"
                        BackgroundColor="Transparent"
                        TextColor="#4D9B91"
                        Clicked="OnViewLogsClicked"
                        VerticalOptions="Center"
                        Padding="8,4"
                        Margin="0,0,10,0" />

                <!-- Settings Button -->
                <Button Grid.Column="6"
                        Text="⚙️"
                        FontSize="18"
                        BackgroundColor="Transparent"
                        TextColor="#4D9B91"
                        Clicked="OnSettingsClicked"
                        VerticalOptions="Center"
                        Padding="8,4"
                        Margin="0,0,10,0" />

                <!-- About Button -->
                <Button Grid.Column="7"
                        Text="ℹ️"
                        FontSize="18"
                        BackgroundColor="Transparent"
                        TextColor="#4D9B91"
                        Clicked="OnAboutClicked"
                        VerticalOptions="Center"
                        Padding="8,4"
                        Margin="0,0,10,0" />

                <!-- Scanning Status -->
                <HorizontalStackLayout Grid.Column="8"
                                       Spacing="8"
                                       VerticalOptions="Center">
                    <Label Text="{Binding StatusIcon}"
                           FontSize="18"
                           VerticalOptions="Center" />
                    <Label Text="{Binding StatusMessage}"
                           FontSize="14"
                           TextColor="#666666"
                           VerticalOptions="Center" />
                    <ActivityIndicator IsRunning="{Binding IsScanning}"
                                       IsVisible="{Binding IsScanning}"
                                       Color="#4D9B91"
                                       WidthRequest="16"
                                       HeightRequest="16" />
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <!-- ─────────────────────────────── Body ─────────────────────────────── -->
        <!-- US0124: Single column. Camera 0 preview at top (when in camera mode), then
             adaptive row of station cards below (cameras + USB). Body width feeds
             MainViewModel.BodyWidth via SizeChanged so CardWidth divides equally. -->
        <Grid Grid.Row="1"
              x:Name="BodyGrid"
              SizeChanged="OnBodyGridSizeChanged"
              RowDefinitions="Auto,*"
              Padding="12,8,12,8"
              BackgroundColor="#F8F9FA">

            <!-- Camera 0 live preview — visible only in camera-active modes -->
            <Border Grid.Row="0"
                    IsVisible="{Binding IsCameraMode}"
                    HeightRequest="240"
                    WidthRequest="320"
                    HorizontalOptions="Center"
                    BackgroundColor="Black"
                    Stroke="#2C5F5D"
                    StrokeThickness="2"
                    Margin="0,4,0,12">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Opacity="0.15" Radius="10" Offset="0,3" />
                </Border.Shadow>
                <controls:CameraPreviewView x:Name="CameraPreview0" />
            </Border>

            <!-- Adaptive station cards row — horizontal flow.
                 Outer HorizontalStackLayout sits the camera FlexLayout and the USB card side by side
                 at their natural widths so they appear: [Cam 1] [Cam 2] [Cam 3] [USB] inline. -->
            <ScrollView Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalScrollBarVisibility="Default"
                        VerticalScrollBarVisibility="Never"
                        SizeChanged="OnCardsAreaSizeChanged">
                <HorizontalStackLayout HorizontalOptions="Center"
                                       VerticalOptions="Fill"
                                       Spacing="0">

                    <!-- Camera slot cards (1–8) — HorizontalStackLayout templated from CameraSlots.
                         FlexLayout previously stacked children on top of each other when its parent
                         was an unconstrained horizontal container (HorizontalStackLayout inside a
                         horizontal ScrollView). HorizontalStackLayout lays out children side by side
                         without needing a parent width constraint. -->
                    <HorizontalStackLayout BindableLayout.ItemsSource="{Binding CameraSlots}"
                                           Spacing="0"
                                           VerticalOptions="Start">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:CameraSlotState">
                                <!-- US0126: ID-card layout — avatar top, 4 detail rows (skeleton/real), device strip bottom. -->
                                <Border IsVisible="{Binding IsVisible}"
                                        WidthRequest="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CardWidth}"
                                        HeightRequest="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CardHeight}"
                                        MinimumWidthRequest="260"
                                        MaximumWidthRequest="520"
                                        Margin="6"
                                        BackgroundColor="White"
                                        Stroke="{Binding DisplayBrush}"
                                        StrokeThickness="2"
                                        Padding="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="14" />
                                    </Border.StrokeShape>
                                    <Border.Shadow>
                                        <Shadow Brush="Black" Opacity="0.08" Radius="10" Offset="0,3" />
                                    </Border.Shadow>

                                    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="0">

                                        <!-- ROW 0: Avatar (skeleton vs. active stacked) -->
                                        <Grid Grid.Row="0"
                                              HorizontalOptions="Center"
                                              Padding="0,18,0,12">
                                            <Border WidthRequest="80"
                                                    HeightRequest="80"
                                                    BackgroundColor="#EEEEEE"
                                                    Stroke="#D0D0D0"
                                                    StrokeThickness="2"
                                                    IsVisible="{Binding ShowFlash, Converter={StaticResource InvertedBoolConverter}}">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="40" />
                                                </Border.StrokeShape>
                                                <Label Text="👤"
                                                       FontSize="36"
                                                       Opacity="0.3"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center" />
                                            </Border>
                                            <Border WidthRequest="80"
                                                    HeightRequest="80"
                                                    BackgroundColor="#E0F2F1"
                                                    Stroke="#4D9B91"
                                                    StrokeThickness="2"
                                                    IsVisible="{Binding ShowFlash}">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="40" />
                                                </Border.StrokeShape>
                                                <Label Text="👤"
                                                       FontSize="36"
                                                       Opacity="0.85"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center" />
                                            </Border>
                                        </Grid>

                                        <!-- ROW 1: 4 labelled detail rows. Skeleton when idle, real values during flash. -->
                                        <VerticalStackLayout Grid.Row="1"
                                                             Padding="20,4,20,14"
                                                             Spacing="10">

                                            <!-- STUDENT NUMBER (hidden for visitor scans) -->
                                            <VerticalStackLayout Spacing="3"
                                                                 IsVisible="{Binding IsVisitorScan, Converter={StaticResource InvertedBoolConverter}}">
                                                <Label Text="STUDENT NUMBER"
                                                       FontSize="13"
                                                       FontAttributes="Bold"
                                                       TextColor="#9E9E9E"
                                                       CharacterSpacing="1.2" />
                                                <Border IsVisible="{Binding ShowFlash, Converter={StaticResource InvertedBoolConverter}}"
                                                        BackgroundColor="#EEEEEE"
                                                        HeightRequest="30"
                                                        StrokeThickness="0">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="4" />
                                                    </Border.StrokeShape>
                                                </Border>
                                                <Label IsVisible="{Binding ShowFlash}"
                                                       Text="{Binding LastStudentId}"
                                                       FontSize="26"
                                                       FontAttributes="Bold"
                                                       TextColor="#2C5F5D"
                                                       LineBreakMode="TailTruncation" />
                                            </VerticalStackLayout>

                                            <!-- STUDENT NAME (always visible — carries "Visitor Pass #N" for visitors) -->
                                            <VerticalStackLayout Spacing="3">
                                                <Label Text="STUDENT NAME"
                                                       FontSize="13"
                                                       FontAttributes="Bold"
                                                       TextColor="#9E9E9E"
                                                       CharacterSpacing="1.2" />
                                                <Border IsVisible="{Binding ShowFlash, Converter={StaticResource InvertedBoolConverter}}"
                                                        BackgroundColor="#EEEEEE"
                                                        HeightRequest="27"
                                                        StrokeThickness="0">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="4" />
                                                    </Border.StrokeShape>
                                                </Border>
                                                <Label IsVisible="{Binding ShowFlash}"
                                                       Text="{Binding FlashStudentName}"
                                                       FontSize="22"
                                                       TextColor="#37474F"
                                                       LineBreakMode="TailTruncation" />
                                            </VerticalStackLayout>

                                            <!-- LRN (hidden for visitor scans) -->
                                            <VerticalStackLayout Spacing="3"
                                                                 IsVisible="{Binding IsVisitorScan, Converter={StaticResource InvertedBoolConverter}}">
                                                <Label Text="LRN"
                                                       FontSize="13"
                                                       FontAttributes="Bold"
                                                       TextColor="#9E9E9E"
                                                       CharacterSpacing="1.2" />
                                                <Border IsVisible="{Binding ShowFlash, Converter={StaticResource InvertedBoolConverter}}"
                                                        BackgroundColor="#EEEEEE"
                                                        HeightRequest="24"
                                                        WidthRequest="160"
                                                        HorizontalOptions="Start"
                                                        StrokeThickness="0">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="4" />
                                                    </Border.StrokeShape>
                                                </Border>
                                                <Label IsVisible="{Binding ShowFlash}"
                                                       Text="{Binding LastLrn, TargetNullValue='N/A'}"
                                                       FontSize="20"
                                                       TextColor="#546E7A"
                                                       LineBreakMode="TailTruncation" />
                                            </VerticalStackLayout>

                                            <!-- GRADE · PROGRAM · SECTION (hidden for visitor scans) -->
                                            <VerticalStackLayout Spacing="3"
                                                                 IsVisible="{Binding IsVisitorScan, Converter={StaticResource InvertedBoolConverter}}">
                                                <Label Text="GRADE · PROGRAM · SECTION"
                                                       FontSize="13"
                                                       FontAttributes="Bold"
                                                       TextColor="#9E9E9E"
                                                       CharacterSpacing="1.2" />
                                                <Border IsVisible="{Binding ShowFlash, Converter={StaticResource InvertedBoolConverter}}"
                                                        BackgroundColor="#EEEEEE"
                                                        HeightRequest="24"
                                                        WidthRequest="200"
                                                        HorizontalOptions="Start"
                                                        StrokeThickness="0">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="4" />
                                                    </Border.StrokeShape>
                                                </Border>
                                                <Label IsVisible="{Binding ShowFlash}"
                                                       Text="{Binding LastGradeSection}"
                                                       FontSize="20"
                                                       TextColor="#37474F"
                                                       LineBreakMode="TailTruncation" />
                                            </VerticalStackLayout>

                                        </VerticalStackLayout>

                                        <!-- ROW 2: Device strip — name on line 1, status on line 2 -->
                                        <Border Grid.Row="2"
                                                BackgroundColor="{Binding BottomStripColor}"
                                                StrokeThickness="0"
                                                Padding="14,12">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="0,0,12,12" />
                                            </Border.StrokeShape>
                                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                                <Label Text="{Binding DisplayName}"
                                                       FontSize="17"
                                                       FontAttributes="Bold"
                                                       TextColor="White"
                                                       HorizontalTextAlignment="Center"
                                                       LineBreakMode="TailTruncation" />
                                                <Label Text="{Binding BottomStripStatusText}"
                                                       FontSize="14"
                                                       TextColor="White"
                                                       Opacity="0.92"
                                                       HorizontalTextAlignment="Center"
                                                       LineBreakMode="TailTruncation" />
                                            </VerticalStackLayout>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>

                    <!-- USB indicator card (peer with camera cards) — US0126 ID-card layout.
                         Sits inline with camera cards in the outer row-flow. -->
                    <Border IsVisible="{Binding UsbScannerSlot.IsVisible}"
                            WidthRequest="{Binding CardWidth}"
                            HeightRequest="{Binding CardHeight}"
                            MinimumWidthRequest="260"
                            MaximumWidthRequest="520"
                            Margin="6"
                            VerticalOptions="Start"
                            BackgroundColor="White"
                            Stroke="{Binding UsbScannerSlot.DisplayColor}"
                            StrokeThickness="2"
                            Padding="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Opacity="0.08" Radius="10" Offset="0,3" />
                        </Border.Shadow>

                        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="0">

                            <!-- ROW 0: Avatar (skeleton vs. active stacked) -->
                            <Grid Grid.Row="0"
                                  HorizontalOptions="Center"
                                  Padding="0,18,0,12">
                                <Border WidthRequest="80"
                                        HeightRequest="80"
                                        BackgroundColor="#EEEEEE"
                                        Stroke="#D0D0D0"
                                        StrokeThickness="2"
                                        IsVisible="{Binding UsbScannerSlot.ShowFlash, Converter={StaticResource InvertedBoolConverter}}">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="40" />
                                    </Border.StrokeShape>
                                    <Label Text="👤"
                                           FontSize="36"
                                           Opacity="0.3"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Border>
                                <Border WidthRequest="80"
                                        HeightRequest="80"
                                        BackgroundColor="#E0F2F1"
                                        Stroke="#4D9B91"
                                        StrokeThickness="2"
                                        IsVisible="{Binding UsbScannerSlot.ShowFlash}">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="40" />
                                    </Border.StrokeShape>
                                    <Label Text="👤"
                                           FontSize="36"
                                           Opacity="0.85"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Border>
                            </Grid>

                            <!-- ROW 1: 4 labelled detail rows -->
                            <VerticalStackLayout Grid.Row="1"
                                                 Padding="20,4,20,14"
                                                 Spacing="10">

                                <!-- STUDENT NUMBER (hidden for visitor scans) -->
                                <VerticalStackLayout Spacing="3"
                                                     IsVisible="{Binding UsbScannerSlot.IsVisitorScan, Converter={StaticResource InvertedBoolConverter}}">
                                    <Label Text="STUDENT NUMBER"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="#9E9E9E"
                                           CharacterSpacing="1.2" />
                                    <Border IsVisible="{Binding UsbScannerSlot.ShowFlash, Converter={StaticResource InvertedBoolConverter}}"
                                            BackgroundColor="#EEEEEE"
                                            HeightRequest="30"
                                            StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="4" />
                                        </Border.StrokeShape>
                                    </Border>
                                    <Label IsVisible="{Binding UsbScannerSlot.ShowFlash}"
                                           Text="{Binding UsbScannerSlot.LastStudentId}"
                                           FontSize="26"
                                           FontAttributes="Bold"
                                           TextColor="#2C5F5D"
                                           LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>

                                <!-- STUDENT NAME (always visible) -->
                                <VerticalStackLayout Spacing="3">
                                    <Label Text="STUDENT NAME"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="#9E9E9E"
                                           CharacterSpacing="1.2" />
                                    <Border IsVisible="{Binding UsbScannerSlot.ShowFlash, Converter={StaticResource InvertedBoolConverter}}"
                                            BackgroundColor="#EEEEEE"
                                            HeightRequest="27"
                                            StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="4" />
                                        </Border.StrokeShape>
                                    </Border>
                                    <Label IsVisible="{Binding UsbScannerSlot.ShowFlash}"
                                           Text="{Binding UsbScannerSlot.FlashStudentName}"
                                           FontSize="22"
                                           TextColor="#37474F"
                                           LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>

                                <!-- LRN (hidden for visitor scans) -->
                                <VerticalStackLayout Spacing="3"
                                                     IsVisible="{Binding UsbScannerSlot.IsVisitorScan, Converter={StaticResource InvertedBoolConverter}}">
                                    <Label Text="LRN"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="#9E9E9E"
                                           CharacterSpacing="1.2" />
                                    <Border IsVisible="{Binding UsbScannerSlot.ShowFlash, Converter={StaticResource InvertedBoolConverter}}"
                                            BackgroundColor="#EEEEEE"
                                            HeightRequest="24"
                                            WidthRequest="160"
                                            HorizontalOptions="Start"
                                            StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="4" />
                                        </Border.StrokeShape>
                                    </Border>
                                    <Label IsVisible="{Binding UsbScannerSlot.ShowFlash}"
                                           Text="{Binding UsbScannerSlot.LastLrn, TargetNullValue='N/A'}"
                                           FontSize="20"
                                           TextColor="#546E7A"
                                           LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>

                                <!-- GRADE · PROGRAM · SECTION (hidden for visitor scans) -->
                                <VerticalStackLayout Spacing="3"
                                                     IsVisible="{Binding UsbScannerSlot.IsVisitorScan, Converter={StaticResource InvertedBoolConverter}}">
                                    <Label Text="GRADE · PROGRAM · SECTION"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="#9E9E9E"
                                           CharacterSpacing="1.2" />
                                    <Border IsVisible="{Binding UsbScannerSlot.ShowFlash, Converter={StaticResource InvertedBoolConverter}}"
                                            BackgroundColor="#EEEEEE"
                                            HeightRequest="24"
                                            WidthRequest="200"
                                            HorizontalOptions="Start"
                                            StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="4" />
                                        </Border.StrokeShape>
                                    </Border>
                                    <Label IsVisible="{Binding UsbScannerSlot.ShowFlash}"
                                           Text="{Binding UsbScannerSlot.LastGradeSection}"
                                           FontSize="20"
                                           TextColor="#37474F"
                                           LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>

                            </VerticalStackLayout>

                            <!-- ROW 2: Device strip — name on line 1, status on line 2 -->
                            <Border Grid.Row="2"
                                    BackgroundColor="{Binding UsbScannerSlot.BottomStripColor}"
                                    StrokeThickness="0"
                                    Padding="14,12">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="0,0,12,12" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                    <Label Text="{Binding UsbScannerSlot.DisplayName}"
                                           FontSize="17"
                                           FontAttributes="Bold"
                                           TextColor="White"
                                           HorizontalTextAlignment="Center"
                                           LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding UsbScannerSlot.BottomStripStatusText}"
                                           FontSize="14"
                                           TextColor="White"
                                           Opacity="0.92"
                                           HorizontalTextAlignment="Center"
                                           LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </Border>

                </HorizontalStackLayout>
            </ScrollView>
        </Grid>
        <!-- /Body -->

        <!-- ─────────────────────── Statistics Footer ─────────────────────── -->
        <!-- US0013: queue / today / sync cards. US0124 adds inline sync status label. -->
        <Border Grid.Row="2"
                BackgroundColor="#2C5F5D"
                Padding="24,16"
                StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.3" Radius="12" Offset="0,-4" />
            </Border.Shadow>

            <VerticalStackLayout Spacing="6">

                <HorizontalStackLayout Spacing="20" HorizontalOptions="Center">
                    <!-- Queue Count Card -->
                    <Border BackgroundColor="#33FFFFFF"
                            Padding="16,10"
                            StrokeThickness="0"
                            IsVisible="{Binding HasQueuedScans}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnViewQueueClicked" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="10">
                            <Border WidthRequest="40"
                                    HeightRequest="40"
                                    BackgroundColor="#FFC107"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="20" />
                                </Border.StrokeShape>
                                <Label Text="📥"
                                       FontSize="20"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Queue"
                                       FontSize="12"
                                       TextColor="#B0BEC5"
                                       VerticalOptions="End" />
                                <HorizontalStackLayout Spacing="4">
                                    <Label Text="{Binding QueuePendingCount}"
                                           FontSize="18"
                                           TextColor="White"
                                           FontAttributes="Bold"
                                           VerticalOptions="Start" />
                                    <Label Text="pending"
                                           FontSize="12"
                                           TextColor="#B0BEC5"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Today's Scan Count -->
                    <Border BackgroundColor="#33FFFFFF"
                            Padding="16,10"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <HorizontalStackLayout Spacing="10">
                            <Border WidthRequest="40"
                                    HeightRequest="40"
                                    BackgroundColor="#4CAF50"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="20" />
                                </Border.StrokeShape>
                                <Label Text="📊"
                                       FontSize="20"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Today"
                                       FontSize="12"
                                       TextColor="#B0BEC5"
                                       VerticalOptions="End" />
                                <HorizontalStackLayout Spacing="4">
                                    <Label Text="{Binding TodayScanCount}"
                                           FontSize="18"
                                           TextColor="White"
                                           FontAttributes="Bold"
                                           VerticalOptions="Start" />
                                    <Label Text="scans"
                                           FontSize="12"
                                           TextColor="#B0BEC5"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Manual Sync Button -->
                    <Border BackgroundColor="#33FFFFFF"
                            Padding="16,10"
                            StrokeThickness="0"
                            IsVisible="{Binding HasQueuedScans}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ManualSyncCommand}" />
                        </Border.GestureRecognizers>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <HorizontalStackLayout Spacing="10">
                            <Border WidthRequest="40"
                                    HeightRequest="40"
                                    BackgroundColor="#2196F3"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="20" />
                                </Border.StrokeShape>
                                <Label Text="🔄"
                                       FontSize="20"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Sync"
                                       FontSize="12"
                                       TextColor="#B0BEC5"
                                       VerticalOptions="End" />
                                <Label Text="Tap to sync"
                                       FontSize="12"
                                       TextColor="#B0BEC5"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center" />
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Border>
                </HorizontalStackLayout>

                <!-- US0124: Inline sync / queue status message (replaces deleted bottom feedback banner) -->
                <Label Text="{Binding SyncStatusMessage}"
                       FontSize="12"
                       TextColor="White"
                       Opacity="0.85"
                       HorizontalOptions="Center"
                       IsVisible="{Binding HasSyncStatusMessage}" />
            </VerticalStackLayout>
        </Border>

    </Grid>
</ContentPage>
