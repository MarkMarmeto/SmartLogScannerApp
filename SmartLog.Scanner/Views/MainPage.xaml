<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SmartLog.Scanner.ViewModels"
             xmlns:controls="clr-namespace:SmartLog.Scanner.Controls"
             x:Class="SmartLog.Scanner.Views.MainPage"
             x:DataType="vm:MainViewModel"
             Title="SmartLog Scanner"
             BackgroundColor="#F8F9FA">

    <!-- Main layout: StatusBar / CameraGrid / CardArea / Feedback / Stats -->
    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">

        <!-- Top Status Bar -->
        <Border Grid.Row="0"
                BackgroundColor="White"
                Padding="20,15"
                StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.1" Radius="8" Offset="0,2" />
            </Border.Shadow>

            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto,Auto,Auto,Auto">
                <!-- US0092: Date/Time block — left-most for glance readability -->
                <VerticalStackLayout Grid.Column="0"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Start"
                                     Spacing="0"
                                     Margin="0,0,16,0">
                    <Label Text="{Binding CurrentTime}"
                           Style="{StaticResource HeaderTimeLabel}" />
                    <Label Text="{Binding CurrentDate}"
                           Style="{StaticResource HeaderDateLabel}" />
                </VerticalStackLayout>

                <!-- App Logo -->
                <Image Grid.Column="1"
                       Source="smartlog_logo.svg"
                       HeightRequest="30"
                       WidthRequest="154"
                       Aspect="AspectFit"
                       VerticalOptions="Center"
                       Margin="0,0,12,0" />

                <!-- Spacer -->
                <BoxView Grid.Column="2" Color="Transparent" />

                <!-- US0015: Enhanced Connectivity Status with Glass Effect -->
                <Border Grid.Column="3"
                        BackgroundColor="{Binding ConnectivityColor}"
                        Padding="14,8"
                        StrokeThickness="0"
                        VerticalOptions="Center"
                        Margin="0,0,10,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="{Binding ConnectivityColor}" Opacity="0.3" Radius="6" Offset="0,2" />
                    </Border.Shadow>
                    <HorizontalStackLayout Spacing="8">
                        <Border WidthRequest="8"
                                HeightRequest="8"
                                BackgroundColor="White"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="4" />
                            </Border.StrokeShape>
                        </Border>
                        <Label Text="{Binding ConnectivityStatus}"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="White"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <!-- US0009: Modern Scan Type Toggle with Icon -->
                <Border Grid.Column="4"
                        BackgroundColor="#4D9B91"
                        Padding="18,10"
                        StrokeThickness="0"
                        VerticalOptions="Center"
                        Margin="0,0,10,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#4D9B91" Opacity="0.4" Radius="8" Offset="0,3" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleScanTypeCommand}" />
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="🔄"
                               FontSize="16"
                               VerticalOptions="Center" />
                        <Label Text="{Binding CurrentScanType, StringFormat='{0} Mode'}"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="White"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <!-- View Logs Button -->
                <Button Grid.Column="5"
                        Text="📊"
                        FontSize="18"
                        BackgroundColor="Transparent"
                        TextColor="#4D9B91"
                        Clicked="OnViewLogsClicked"
                        VerticalOptions="Center"
                        Padding="8,4"
                        Margin="0,0,10,0" />

                <!-- Settings Button -->
                <Button Grid.Column="6"
                        Text="⚙️"
                        FontSize="18"
                        BackgroundColor="Transparent"
                        TextColor="#4D9B91"
                        Clicked="OnSettingsClicked"
                        VerticalOptions="Center"
                        Padding="8,4"
                        Margin="0,0,10,0" />

                <!-- About Button -->
                <Button Grid.Column="7"
                        Text="ℹ️"
                        FontSize="18"
                        BackgroundColor="Transparent"
                        TextColor="#4D9B91"
                        Clicked="OnAboutClicked"
                        VerticalOptions="Center"
                        Padding="8,4"
                        Margin="0,0,10,0" />

                <!-- Scanning Status -->
                <HorizontalStackLayout Grid.Column="8"
                                       Spacing="8"
                                       VerticalOptions="Center">
                    <Label Text="{Binding StatusIcon}"
                           FontSize="18"
                           VerticalOptions="Center" />
                    <Label Text="{Binding StatusMessage}"
                           FontSize="14"
                           TextColor="#666666"
                           VerticalOptions="Center" />
                    <ActivityIndicator IsRunning="{Binding IsScanning}"
                                       IsVisible="{Binding IsScanning}"
                                       Color="#4D9B91"
                                       WidthRequest="16"
                                       HeightRequest="16" />
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <!-- EP0011: Camera row (Row 1) — preview on the left, status cards on the right.
             Hidden in USB mode. -->
        <Grid Grid.Row="1"
              IsVisible="{Binding IsCameraMode}"
              ColumnDefinitions="320,*"
              Padding="12,8">

            <!-- Camera 0 live preview — single AVCaptureVideoPreviewLayer attached after start -->
            <Border Grid.Column="0"
                    WidthRequest="320"
                    HeightRequest="240"
                    BackgroundColor="Black"
                    Stroke="#2C5F5D"
                    StrokeThickness="2"
                    Margin="0,6,8,6">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Opacity="0.15" Radius="10" Offset="0,3" />
                </Border.Shadow>
                <controls:CameraPreviewView x:Name="CameraPreview0" />
            </Border>

            <!-- Status cards for all cameras (including camera 0) -->
            <FlexLayout Grid.Column="1"
                        BindableLayout.ItemsSource="{Binding CameraSlots}"
                        Wrap="Wrap"
                        Direction="Row"
                        JustifyContent="Start"
                        AlignItems="Start">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="vm:CameraSlotState">
                        <Border IsVisible="{Binding IsVisible}"
                                WidthRequest="200"
                                Margin="6"
                                BackgroundColor="White"
                                Stroke="{Binding StatusBrush}"
                                StrokeThickness="2"
                                Padding="14,12">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Opacity="0.07" Radius="8" Offset="0,2" />
                            </Border.Shadow>

                            <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="4">
                                <!-- Camera name + scan type badge -->
                                <Grid Grid.Row="0"
                                      ColumnDefinitions="*,Auto"
                                      Margin="0,0,0,4">
                                    <Label Grid.Column="0"
                                           Text="{Binding DisplayName}"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="#2C5F5D"
                                           VerticalOptions="Center"
                                           LineBreakMode="TailTruncation" />
                                    <Border Grid.Column="1"
                                            BackgroundColor="{Binding ScanTypeBadgeColor}"
                                            Padding="7,2"
                                            StrokeThickness="0"
                                            VerticalOptions="Center">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="4" />
                                        </Border.StrokeShape>
                                        <Label Text="{Binding ScanType}"
                                               FontSize="10"
                                               FontAttributes="Bold"
                                               TextColor="White" />
                                    </Border>
                                </Grid>

                                <!-- Status text -->
                                <Label Grid.Row="1"
                                       Text="{Binding StatusText}"
                                       FontSize="12"
                                       TextColor="#666666" />

                                <!-- Last scan name (shown briefly after a successful scan) -->
                                <Label Grid.Row="2"
                                       Text="{Binding FlashStudentName}"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#4CAF50"
                                       IsVisible="{Binding ShowFlash}" />

                                <!-- Restart button — only when error/offline -->
                                <Button Grid.Row="3"
                                        Text="↺ Restart"
                                        Command="{Binding RestartCommand}"
                                        IsVisible="{Binding CanRestart}"
                                        FontSize="11"
                                        Padding="10,5"
                                        Margin="0,4,0,0"
                                        BackgroundColor="#F44336"
                                        TextColor="White"
                                        CornerRadius="6"
                                        HorizontalOptions="Start" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </FlexLayout>
        </Grid>

        <!-- Student ID Card Area (Row 2) -->
        <Grid Grid.Row="2" BackgroundColor="#F8F9FA">

            <!-- Centered Student ID Card -->
            <Border x:Name="studentCard"
                    WidthRequest="480"
                    HeightRequest="580"
                    BackgroundColor="White"
                    Stroke="{Binding CardBorderColor}"
                    StrokeThickness="3"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="{Binding CardBorderColor}"
                            Opacity="0.3"
                            Radius="20"
                            Offset="0,6" />
                </Border.Shadow>

                <Grid RowDefinitions="Auto,Auto,*,Auto">

                    <!-- Card Header (school teal banner) -->
                    <Border Grid.Row="0"
                            BackgroundColor="#2C5F5D"
                            Padding="20,16"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="17,17,0,0" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                            <Label Text="STUDENT IDENTIFICATION"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   CharacterSpacing="2"
                                   HorizontalTextAlignment="Center" />
                            <Label Text="SmartLog Attendance System"
                                   FontSize="13"
                                   TextColor="#A0D5CF"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Avatar -->
                    <Grid Grid.Row="1"
                          HorizontalOptions="Center"
                          Margin="0,24,0,8">
                        <!-- Skeleton avatar (no data) -->
                        <Border WidthRequest="120"
                                HeightRequest="120"
                                BackgroundColor="#EEEEEE"
                                Stroke="#D0D0D0"
                                StrokeThickness="2"
                                IsVisible="{Binding HasScannedStudent, Converter={StaticResource InvertedBoolConverter}}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="60" />
                            </Border.StrokeShape>
                            <Label Text="👤"
                                   FontSize="54"
                                   Opacity="0.3"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                        <!-- Active avatar (has data) -->
                        <Border WidthRequest="120"
                                HeightRequest="120"
                                BackgroundColor="#E0F2F1"
                                Stroke="#4D9B91"
                                StrokeThickness="2"
                                IsVisible="{Binding HasScannedStudent}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="60" />
                            </Border.StrokeShape>
                            <Label Text="👤"
                                   FontSize="54"
                                   Opacity="0.85"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                    </Grid>

                    <!-- Card Fields -->
                    <VerticalStackLayout Grid.Row="2"
                                         Spacing="20"
                                         Padding="40,16,40,0"
                                         VerticalOptions="Start">

                        <!-- Student Number -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="STUDENT NUMBER"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#9E9E9E"
                                   CharacterSpacing="1.5" />
                            <!-- Skeleton -->
                            <Border IsVisible="{Binding HasScannedStudent, Converter={StaticResource InvertedBoolConverter}}"
                                    BackgroundColor="#EEEEEE"
                                    HeightRequest="34"
                                    StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="6" />
                                </Border.StrokeShape>
                            </Border>
                            <!-- Data -->
                            <Label IsVisible="{Binding HasScannedStudent}"
                                   Text="{Binding LastStudentId}"
                                   FontSize="28"
                                   FontAttributes="Bold"
                                   TextColor="#2C5F5D" />
                        </VerticalStackLayout>

                        <!-- LRN -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="LRN"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#9E9E9E"
                                   CharacterSpacing="1.5" />
                            <!-- Skeleton -->
                            <Border IsVisible="{Binding HasScannedStudent, Converter={StaticResource InvertedBoolConverter}}"
                                    BackgroundColor="#EEEEEE"
                                    HeightRequest="26"
                                    WidthRequest="160"
                                    StrokeThickness="0"
                                    HorizontalOptions="Start">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="6" />
                                </Border.StrokeShape>
                            </Border>
                            <!-- Data -->
                            <Label IsVisible="{Binding HasScannedStudent}"
                                   Text="{Binding LastLrn, TargetNullValue='N/A'}"
                                   FontSize="20"
                                   TextColor="#546E7A" />
                        </VerticalStackLayout>

                        <!-- Student Name -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="STUDENT NAME"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#9E9E9E"
                                   CharacterSpacing="1.5" />
                            <!-- Skeleton -->
                            <Border IsVisible="{Binding HasScannedStudent, Converter={StaticResource InvertedBoolConverter}}"
                                    BackgroundColor="#EEEEEE"
                                    HeightRequest="30"
                                    StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="6" />
                                </Border.StrokeShape>
                            </Border>
                            <!-- Data -->
                            <Label IsVisible="{Binding HasScannedStudent}"
                                   Text="{Binding LastStudentName}"
                                   FontSize="22"
                                   TextColor="#37474F" />
                        </VerticalStackLayout>

                        <!-- Grade & Section -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="GRADE &amp; SECTION"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#9E9E9E"
                                   CharacterSpacing="1.5" />
                            <!-- Skeleton -->
                            <Border IsVisible="{Binding HasScannedStudent, Converter={StaticResource InvertedBoolConverter}}"
                                    BackgroundColor="#EEEEEE"
                                    HeightRequest="30"
                                    WidthRequest="200"
                                    StrokeThickness="0"
                                    HorizontalOptions="Start">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="6" />
                                </Border.StrokeShape>
                            </Border>
                            <!-- Data -->
                            <Label IsVisible="{Binding HasScannedStudent}"
                                   Text="{Binding LastGradeSection}"
                                   FontSize="22"
                                   TextColor="#37474F"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <!-- Card Footer -->
                    <Border Grid.Row="3"
                            BackgroundColor="#FAFAFA"
                            Padding="16,14"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="0,0,17,17" />
                        </Border.StrokeShape>
                        <Grid>
                            <!-- Scan hint (skeleton state) -->
                            <HorizontalStackLayout Spacing="8"
                                                   HorizontalOptions="Center"
                                                   IsVisible="{Binding HasScannedStudent, Converter={StaticResource InvertedBoolConverter}}">
                                <Label Text="📷"
                                       FontSize="14"
                                       VerticalOptions="Center" />
                                <Label Text="Scan a student QR code"
                                       FontSize="13"
                                       TextColor="#9E9E9E"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <!-- Scan time (data state) -->
                            <HorizontalStackLayout Spacing="8"
                                                   HorizontalOptions="Center"
                                                   IsVisible="{Binding HasScannedStudent}">
                                <Label Text="🕒"
                                       FontSize="14"
                                       VerticalOptions="Center" />
                                <Label Text="{Binding LastScanTime, StringFormat='Scanned at {0}'}"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="#4D9B91"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Enhanced Bottom Feedback Panel with Modern Design -->
        <Border Grid.Row="3"
                IsVisible="{Binding ShowFeedback}"
                BackgroundColor="{Binding FeedbackColor}"
                Padding="24,20"
                StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.25" Radius="16" Offset="0,-6" />
            </Border.Shadow>

            <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                <!-- Large Status Icon with Background Circle -->
                <Border Grid.Column="0" Grid.RowSpan="2"
                        WidthRequest="56"
                        HeightRequest="56"
                        BackgroundColor="#33FFFFFF"
                        Margin="0,0,20,0"
                        VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="28" />
                    </Border.StrokeShape>
                    <Label Text="{Binding StatusIcon}"
                           FontSize="28"
                           TextColor="White"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>

                <!-- Scan Message with Better Typography -->
                <Label Grid.Column="1" Grid.Row="0"
                       Text="{Binding LastScanMessage}"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="White"
                       LineBreakMode="WordWrap"
                       VerticalOptions="End"
                       Margin="0,0,0,4" />

                <!-- Scan Time with Icon -->
                <HorizontalStackLayout Grid.Column="1" Grid.Row="1"
                                       Spacing="6"
                                       VerticalOptions="Start">
                    <Label Text="🕒"
                           FontSize="12"
                           VerticalOptions="Center" />
                    <Label Text="{Binding LastScanTime, StringFormat='{0}'}"
                           FontSize="13"
                           TextColor="White"
                           Opacity="0.85"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>

                <!-- Scan Type Badge -->
                <Border Grid.Column="2" Grid.RowSpan="2"
                        BackgroundColor="#33FFFFFF"
                        Padding="12,6"
                        VerticalOptions="Center"
                        StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <Label Text="{Binding CurrentScanType}"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="White"
                           VerticalOptions="Center" />
                </Border>
            </Grid>
        </Border>

        <!-- Modern Ready State with Pulsing Animation Hint -->
        <Border Grid.Row="3"
                IsVisible="{Binding ShowFeedback, Converter={StaticResource InvertedBoolConverter}}"
                BackgroundColor="White"
                Padding="24,20"
                StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.08" Radius="16" Offset="0,-6" />
            </Border.Shadow>

            <HorizontalStackLayout Spacing="16" HorizontalOptions="Center">
                <!-- Animated Ready Icon -->
                <Border WidthRequest="48"
                        HeightRequest="48"
                        BackgroundColor="#E0F2F1"
                        VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>
                    <Label Text="{Binding StatusIcon}"
                           FontSize="24"
                           TextColor="#4D9B91"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>

                <!-- Status Message -->
                <VerticalStackLayout Spacing="4" VerticalOptions="Center">
                    <Label Text="{Binding StatusMessage}"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#37474F"
                           VerticalOptions="Center" />
                    <Label Text="Ready for next scan"
                           FontSize="12"
                           TextColor="#78909C"
                           VerticalOptions="Center" />
                </VerticalStackLayout>
            </HorizontalStackLayout>
        </Border>

        <!-- US0013: Modern Statistics Footer with Card Design -->
        <Border Grid.Row="4"
                BackgroundColor="#2C5F5D"
                Padding="24,16"
                StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.3" Radius="12" Offset="0,-4" />
            </Border.Shadow>

            <HorizontalStackLayout Spacing="20" HorizontalOptions="Center">
                <!-- Queue Count Card (visible when scans are queued) -->
                <Border BackgroundColor="#33FFFFFF"
                        Padding="16,10"
                        StrokeThickness="0"
                        IsVisible="{Binding HasQueuedScans}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnViewQueueClicked" />
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="10">
                        <Border WidthRequest="40"
                                HeightRequest="40"
                                BackgroundColor="#FFC107"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20" />
                            </Border.StrokeShape>
                            <Label Text="📥"
                                   FontSize="20"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Queue"
                                   FontSize="12"
                                   TextColor="#B0BEC5"
                                   VerticalOptions="End" />
                            <HorizontalStackLayout Spacing="4">
                                <Label Text="{Binding QueuePendingCount}"
                                       FontSize="18"
                                       TextColor="White"
                                       FontAttributes="Bold"
                                       VerticalOptions="Start" />
                                <Label Text="pending"
                                       FontSize="12"
                                       TextColor="#B0BEC5"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Border>

                <!-- Today's Scan Count Card -->
                <Border BackgroundColor="#33FFFFFF"
                        Padding="16,10"
                        StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <HorizontalStackLayout Spacing="10">
                        <Border WidthRequest="40"
                                HeightRequest="40"
                                BackgroundColor="#4CAF50"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20" />
                            </Border.StrokeShape>
                            <Label Text="📊"
                                   FontSize="20"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Today"
                                   FontSize="12"
                                   TextColor="#B0BEC5"
                                   VerticalOptions="End" />
                            <HorizontalStackLayout Spacing="4">
                                <Label Text="{Binding TodayScanCount}"
                                       FontSize="18"
                                       TextColor="White"
                                       FontAttributes="Bold"
                                       VerticalOptions="Start" />
                                <Label Text="scans"
                                       FontSize="12"
                                       TextColor="#B0BEC5"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Border>

                <!-- Manual Sync Button Card (visible when queue has items) -->
                <Border BackgroundColor="#33FFFFFF"
                        Padding="16,10"
                        StrokeThickness="0"
                        IsVisible="{Binding HasQueuedScans}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ManualSyncCommand}" />
                    </Border.GestureRecognizers>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <HorizontalStackLayout Spacing="10">
                        <Border WidthRequest="40"
                                HeightRequest="40"
                                BackgroundColor="#2196F3"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20" />
                            </Border.StrokeShape>
                            <Label Text="🔄"
                                   FontSize="20"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Sync"
                                   FontSize="12"
                                   TextColor="#B0BEC5"
                                   VerticalOptions="End" />
                            <Label Text="Tap to sync"
                                   FontSize="12"
                                   TextColor="#B0BEC5"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Border>
            </HorizontalStackLayout>
        </Border>

    </Grid>
</ContentPage>
