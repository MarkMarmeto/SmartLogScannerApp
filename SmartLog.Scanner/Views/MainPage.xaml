<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SmartLog.Scanner.ViewModels"
             xmlns:controls="clr-namespace:SmartLog.Scanner.Controls"
             x:Class="SmartLog.Scanner.Views.MainPage"
             x:DataType="vm:MainViewModel"
             Title="SmartLog Scanner"
             BackgroundColor="#F5F5F5">

    <!-- Modern Grid Layout -->
    <Grid RowDefinitions="Auto,*,Auto,Auto">

        <!-- Top Status Bar -->
        <Border Grid.Row="0"
                BackgroundColor="White"
                Padding="20,15"
                StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.1" Radius="8" Offset="0,2" />
            </Border.Shadow>

            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto">
                <!-- App Title -->
                <Label Grid.Column="0"
                       Text="SmartLog Scanner"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="#1976D2"
                       VerticalOptions="Center" />

                <!-- US0015: Enhanced Connectivity Status with Glass Effect -->
                <Border Grid.Column="2"
                        BackgroundColor="{Binding ConnectivityColor}"
                        Padding="14,8"
                        StrokeThickness="0"
                        VerticalOptions="Center"
                        Margin="0,0,10,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="{Binding ConnectivityColor}" Opacity="0.3" Radius="6" Offset="0,2" />
                    </Border.Shadow>
                    <HorizontalStackLayout Spacing="8">
                        <Border WidthRequest="8"
                                HeightRequest="8"
                                BackgroundColor="White"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="4" />
                            </Border.StrokeShape>
                        </Border>
                        <Label Text="{Binding ConnectivityStatus}"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="White"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <!-- US0009: Modern Scan Type Toggle with Icon -->
                <Border Grid.Column="3"
                        BackgroundColor="#1976D2"
                        Padding="18,10"
                        StrokeThickness="0"
                        VerticalOptions="Center"
                        Margin="0,0,10,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#1976D2" Opacity="0.4" Radius="8" Offset="0,3" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleScanTypeCommand}" />
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="🔄"
                               FontSize="16"
                               VerticalOptions="Center" />
                        <Label Text="{Binding CurrentScanType, StringFormat='{0} Mode'}"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="White"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <!-- Settings Button -->
                <Button Grid.Column="4"
                        Text="⚙️"
                        FontSize="18"
                        BackgroundColor="Transparent"
                        TextColor="#1976D2"
                        Clicked="OnSettingsClicked"
                        VerticalOptions="Center"
                        Padding="8,4"
                        Margin="0,0,10,0" />

                <!-- Scanning Status -->
                <HorizontalStackLayout Grid.Column="5"
                                       Spacing="8"
                                       VerticalOptions="Center">
                    <Label Text="{Binding StatusIcon}"
                           FontSize="18"
                           VerticalOptions="Center" />
                    <Label Text="{Binding StatusMessage}"
                           FontSize="14"
                           TextColor="#666666"
                           VerticalOptions="Center" />
                    <ActivityIndicator IsRunning="{Binding IsScanning}"
                                       IsVisible="{Binding IsScanning}"
                                       Color="#1976D2"
                                       WidthRequest="16"
                                       HeightRequest="16" />
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <!-- Camera Preview Area with Modern Scanning Frame -->
        <Grid Grid.Row="1">
            <!-- Live Camera View -->
            <controls:CameraQrView x:Name="cameraView"
                                   IsDetecting="{Binding IsScanning}"
                                   BarcodeDetected="OnBarcodeDetected" />

            <!-- Modern Corner Bracket Scanning Frame -->
            <Grid WidthRequest="320"
                  HeightRequest="320"
                  HorizontalOptions="Center"
                  VerticalOptions="Center">

                <!-- Top-Left Corner -->
                <Grid HorizontalOptions="Start" VerticalOptions="Start">
                    <BoxView Color="#1976D2" WidthRequest="60" HeightRequest="4"
                             HorizontalOptions="Start" VerticalOptions="Start" />
                    <BoxView Color="#1976D2" WidthRequest="4" HeightRequest="60"
                             HorizontalOptions="Start" VerticalOptions="Start" />
                </Grid>

                <!-- Top-Right Corner -->
                <Grid HorizontalOptions="End" VerticalOptions="Start">
                    <BoxView Color="#1976D2" WidthRequest="60" HeightRequest="4"
                             HorizontalOptions="End" VerticalOptions="Start" />
                    <BoxView Color="#1976D2" WidthRequest="4" HeightRequest="60"
                             HorizontalOptions="End" VerticalOptions="Start" />
                </Grid>

                <!-- Bottom-Left Corner -->
                <Grid HorizontalOptions="Start" VerticalOptions="End">
                    <BoxView Color="#1976D2" WidthRequest="60" HeightRequest="4"
                             HorizontalOptions="Start" VerticalOptions="End" />
                    <BoxView Color="#1976D2" WidthRequest="4" HeightRequest="60"
                             HorizontalOptions="Start" VerticalOptions="End" />
                </Grid>

                <!-- Bottom-Right Corner -->
                <Grid HorizontalOptions="End" VerticalOptions="End">
                    <BoxView Color="#1976D2" WidthRequest="60" HeightRequest="4"
                             HorizontalOptions="End" VerticalOptions="End" />
                    <BoxView Color="#1976D2" WidthRequest="4" HeightRequest="60"
                             HorizontalOptions="End" VerticalOptions="End" />
                </Grid>

                <!-- Glass morphism Scan Hint -->
                <Border BackgroundColor="#CC000000"
                        Padding="20,12"
                        HorizontalOptions="Center"
                        VerticalOptions="End"
                        Margin="0,0,0,30"
                        StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.3" Radius="8" Offset="0,4" />
                    </Border.Shadow>

                    <HorizontalStackLayout Spacing="10">
                        <Label Text="📷"
                               FontSize="16"
                               VerticalOptions="Center" />
                        <Label Text="Position QR code within brackets"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="White"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>
            </Grid>
        </Grid>

        <!-- Enhanced Bottom Feedback Panel with Modern Design -->
        <Border Grid.Row="2"
                IsVisible="{Binding ShowFeedback}"
                BackgroundColor="{Binding FeedbackColor}"
                Padding="24,20"
                StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.25" Radius="16" Offset="0,-6" />
            </Border.Shadow>

            <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                <!-- Large Status Icon with Background Circle -->
                <Border Grid.Column="0" Grid.RowSpan="2"
                        WidthRequest="56"
                        HeightRequest="56"
                        BackgroundColor="#33FFFFFF"
                        Margin="0,0,20,0"
                        VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="28" />
                    </Border.StrokeShape>
                    <Label Text="{Binding StatusIcon}"
                           FontSize="28"
                           TextColor="White"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>

                <!-- Scan Message with Better Typography -->
                <Label Grid.Column="1" Grid.Row="0"
                       Text="{Binding LastScanMessage}"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="White"
                       LineBreakMode="WordWrap"
                       VerticalOptions="End"
                       Margin="0,0,0,4" />

                <!-- Scan Time with Icon -->
                <HorizontalStackLayout Grid.Column="1" Grid.Row="1"
                                       Spacing="6"
                                       VerticalOptions="Start">
                    <Label Text="🕒"
                           FontSize="12"
                           VerticalOptions="Center" />
                    <Label Text="{Binding LastScanTime, StringFormat='{0}'}"
                           FontSize="13"
                           TextColor="White"
                           Opacity="0.85"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>

                <!-- Scan Type Badge -->
                <Border Grid.Column="2" Grid.RowSpan="2"
                        BackgroundColor="#33FFFFFF"
                        Padding="12,6"
                        VerticalOptions="Center"
                        StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <Label Text="{Binding CurrentScanType}"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="White"
                           VerticalOptions="Center" />
                </Border>
            </Grid>
        </Border>

        <!-- Modern Ready State with Pulsing Animation Hint -->
        <Border Grid.Row="2"
                IsVisible="{Binding ShowFeedback, Converter={StaticResource InvertedBoolConverter}}"
                BackgroundColor="White"
                Padding="24,20"
                StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.08" Radius="16" Offset="0,-6" />
            </Border.Shadow>

            <HorizontalStackLayout Spacing="16" HorizontalOptions="Center">
                <!-- Animated Ready Icon -->
                <Border WidthRequest="48"
                        HeightRequest="48"
                        BackgroundColor="#E3F2FD"
                        VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>
                    <Label Text="{Binding StatusIcon}"
                           FontSize="24"
                           TextColor="#1976D2"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>

                <!-- Status Message -->
                <VerticalStackLayout Spacing="4" VerticalOptions="Center">
                    <Label Text="{Binding StatusMessage}"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#37474F"
                           VerticalOptions="Center" />
                    <Label Text="Ready for next scan"
                           FontSize="12"
                           TextColor="#78909C"
                           VerticalOptions="Center" />
                </VerticalStackLayout>
            </HorizontalStackLayout>
        </Border>

        <!-- US0013: Modern Statistics Footer with Card Design -->
        <Border Grid.Row="3"
                BackgroundColor="#263238"
                Padding="24,16"
                StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.3" Radius="12" Offset="0,-4" />
            </Border.Shadow>

            <HorizontalStackLayout Spacing="20" HorizontalOptions="Center">
                <!-- Queue Count Card -->
                <Border BackgroundColor="#33FFFFFF"
                        Padding="16,10"
                        StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <HorizontalStackLayout Spacing="10">
                        <Border WidthRequest="40"
                                HeightRequest="40"
                                BackgroundColor="#FFC107"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20" />
                            </Border.StrokeShape>
                            <Label Text="📥"
                                   FontSize="20"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Queue"
                                   FontSize="12"
                                   TextColor="#B0BEC5"
                                   VerticalOptions="End" />
                            <HorizontalStackLayout Spacing="4">
                                <Label Text="{Binding QueuePendingCount}"
                                       FontSize="18"
                                       TextColor="White"
                                       FontAttributes="Bold"
                                       VerticalOptions="Start" />
                                <Label Text="pending"
                                       FontSize="12"
                                       TextColor="#B0BEC5"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Border>

                <!-- Today's Scan Count Card -->
                <Border BackgroundColor="#33FFFFFF"
                        Padding="16,10"
                        StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <HorizontalStackLayout Spacing="10">
                        <Border WidthRequest="40"
                                HeightRequest="40"
                                BackgroundColor="#4CAF50"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20" />
                            </Border.StrokeShape>
                            <Label Text="📊"
                                   FontSize="20"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Today"
                                   FontSize="12"
                                   TextColor="#B0BEC5"
                                   VerticalOptions="End" />
                            <HorizontalStackLayout Spacing="4">
                                <Label Text="{Binding TodayScanCount}"
                                       FontSize="18"
                                       TextColor="White"
                                       FontAttributes="Bold"
                                       VerticalOptions="Start" />
                                <Label Text="scans"
                                       FontSize="12"
                                       TextColor="#B0BEC5"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Border>
            </HorizontalStackLayout>
        </Border>

    </Grid>
</ContentPage>
