<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:SmartLog.Scanner.Converters"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="SmartLog.Scanner.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- US0004: Value Converters -->
            <converters:StringNotNullOrEmptyConverter x:Key="StringNotNullOrEmptyConverter" />
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />

            <!-- IsNotNullConverter (CommunityToolkit.Maui) -->
            <toolkit:IsNotNullConverter x:Key="IsNotNullConverter" />

            <!-- US0005: Connection Test Converters -->
            <converters:TestingTextConverter x:Key="TestingTextConverter" />
            <converters:EnumNotNoneConverter x:Key="EnumNotNoneConverter" />
            <converters:TestResultIconConverter x:Key="TestResultIconConverter" />
            <converters:TestResultColorConverter x:Key="TestResultColorConverter" />
            <converters:TestResultImageConverter x:Key="TestResultImageConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
