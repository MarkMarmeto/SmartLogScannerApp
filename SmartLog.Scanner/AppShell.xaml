<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SmartLog.Scanner.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:SmartLog.Scanner.Views"
    Shell.FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False"
    BackgroundColor="#F8F9FA">

    <!--
        SetupPage is intentionally NOT a ShellContent here. On Windows,
        the MAUI Shell platform handler renders the first ShellContent
        and ignores subsequent CurrentItem changes, which made
        Setup <-> Main navigation impossible. Setup is shown by swapping
        Application.MainPage in INavigationService instead. Within
        AppShell, Main is the first (default) ShellContent and the
        remaining tabs navigate via Shell.GoToAsync as normal.
    -->
    <TabBar>
        <ShellContent
            Title="Main"
            Route="main"
            ContentTemplate="{DataTemplate local:MainPage}" />

        <ShellContent
            Title="Scan Logs"
            Route="logs"
            ContentTemplate="{DataTemplate local:ScanLogsPage}" />

        <ShellContent
            Title="Offline Queue"
            Route="queue"
            ContentTemplate="{DataTemplate local:OfflineQueuePage}" />

        <ShellContent
            Title="About"
            Route="about"
            ContentTemplate="{DataTemplate local:AboutPage}" />
    </TabBar>

</Shell>
