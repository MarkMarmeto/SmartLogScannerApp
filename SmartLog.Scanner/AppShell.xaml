<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SmartLog.Scanner.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:SmartLog.Scanner.Views"
    Shell.FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False">

    <TabBar>
        <ShellContent
            Title="Setup"
            Route="setup"
            ContentTemplate="{DataTemplate local:SetupPage}" />

        <ShellContent
            Title="Main"
            Route="main"
            ContentTemplate="{DataTemplate local:MainPage}" />

        <ShellContent
            Title="Scan Logs"
            Route="logs"
            ContentTemplate="{DataTemplate local:ScanLogsPage}" />

        <ShellContent
            Title="Offline Queue"
            Route="queue"
            ContentTemplate="{DataTemplate local:OfflineQueuePage}" />

        <ShellContent
            Title="About"
            Route="about"
            ContentTemplate="{DataTemplate local:AboutPage}" />
    </TabBar>

</Shell>
